# Ignore files and folders whose names start with a dot.
**/.*

# DO NOT ignore .git* .
!**/.git*

# DO NOT ignore .development and .vscode .
!**/.development
!**/.vscode

# PlatformIO ignore rules.
**/.pio
**/.vscode/.browse.c_cpp.db*
**/.vscode/c_cpp_properties.json
**/.vscode/launch.json
**/.vscode/ipch
